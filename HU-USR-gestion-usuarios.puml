@startuml HU-USR-gestion-usuarios

left to right direction

title Modulo de Gestion de Usuarios

skinparam backgroundColor #1A1A2E
skinparam actor {
    BackgroundColor #FF9900
    BorderColor #FF6600
    FontColor #FFFFFF
}
skinparam usecase {
    BackgroundColor #232F3E
    BorderColor #FF9900
    FontColor #FFFFFF
}
skinparam package {
    BackgroundColor #2D3748
    BorderColor #FF9900
    FontColor #FF9900
}
skinparam arrowColor #FF9900
skinparam note {
    BackgroundColor #2D3748
    BorderColor #FF9900
    FontColor #FFFFFF
}
skinparam legend {
    BackgroundColor #2D3748
    BorderColor #FF9900
    FontColor #FFFFFF
}

actor "Estudiante" as EST
actor "Profesor" as PROF
actor "Administrador" as ADM

package "Academia Virtual de Matematicas" {
    package "Gestion de Usuarios" {

        ' --- GESTION DE CUENTAS (Admin) ---
        usecase "Crear, editar y\ndesactivar cuentas" as USR01

        usecase "Asignar roles a usuarios" as USR02

        usecase "Buscar usuarios por\nnombre, correo o rol" as USR03

        usecase "Ver detalle de\nusuario" as USR07

        usecase "Exportar listado de\nusuarios" as USR08

        ' --- PERFIL Y PERSONALIZACION ---
        usecase "Editar perfil con\nfoto y bio" as USR04

        usecase "Seleccionar area de\nestudio o especialidad" as USR17

        usecase "Ver perfil publico\nde usuario" as USR09

        usecase "Configurar preferencias\nde privacidad" as USR10

        ' --- SEGUIMIENTO Y ACCESO ---
        usecase "Registrar fecha de\nultimo acceso" as USR05

        usecase "Ver historial de\nsesiones activas" as USR11

        usecase "Cerrar sesion en\ntodos los dispositivos" as USR12

        ' --- APODERADOS ---
        usecase "Gestionar apoderados de\nestudiantes menores" as USR06

        usecase "Vincular cuenta de\napoderado a estudiante" as USR13

        usecase "Recibir resumen de\nprogreso del menor" as USR14

        ' --- AUTENTICACION ---
        usecase "Recuperar contrasena" as USR15

        usecase "Configurar autenticacion\nde dos factores" as USR16
    }
}

' --- ESTUDIANTE ---
EST --> USR04
EST --> USR09
EST --> USR10
EST --> USR11
EST --> USR12
EST --> USR15
EST --> USR16
EST --> USR17

' --- PROFESOR ---
PROF --> USR04
PROF --> USR09
PROF --> USR10
PROF --> USR11
PROF --> USR12
PROF --> USR15
PROF --> USR16
PROF --> USR17

' --- ADMINISTRADOR ---
ADM --> USR01
ADM --> USR02
ADM --> USR03
ADM --> USR05
ADM --> USR06
ADM --> USR07
ADM --> USR08
ADM --> USR13

' --- RELACIONES <<include>> ---
USR01 ..> USR02 : <<include>>
USR01 ..> USR07 : <<include>>

USR06 ..> USR13 : <<include>>
USR13 ..> USR14 : <<include>>

USR04 ..> USR10 : <<include>>

USR17 ..> USR04 : <<include>>

' --- RELACIONES <<extend>> ---
USR03 ..> USR07 : <<extend>>
USR11 ..> USR12 : <<extend>>

USR15 ..> USR16 : <<extend>>

' --- NOTAS EXPLICATIVAS ---
note right of USR01
  El administrador puede:
  - Crear cuenta manualmente
  - Editar datos personales
  - Desactivar (suspender temporalmente)
  - Eliminar permanentemente (con backup)
end note

note right of USR02
  Roles disponibles en el sistema:
  - Estudiante
  - Profesor
  - Administrador
  - Apoderado (solo vinculado a menor)
  - Auditor (solo lectura)
end note

note right of USR17
  Areas de estudio disponibles:
  - Algebra y Trigonometria
  - Calculo Diferencial e Integral
  - Ecuaciones Diferenciales
  - Estadistica y Probabilidad
  - Geometria Analitica
  - Matematicas Discretas
end note

note right of USR06
  Gestion de apoderados:
  - Vincular cuenta de padre/tutor
  - Ver progreso del estudiante menor
  - Recibir alertas de desempeno
  - Autorizar compras o suscripciones
end note

note right of USR16
  Autenticacion de dos factores:
  - App autenticador (Google Authenticator)
  - SMS al numero registrado
  - Email con codigo de verificacion
  - Claves de respaldo de un solo uso
end note

' --- LEYENDA ---
legend right

| |= LEYENDA - Gestion de Usuarios | |
| --> | Asociacion actor -> caso de uso |
| ..> | Dependencia UML |
| <<include>> | Flujo obligatorio |
| <<extend>> | Flujo alternativo |

endlegend

@enduml