@startuml HU-EJP-ejercicios-parametrizados
left to right direction
skinparam backgroundColor #1A1A2E
skinparam actorBackgroundColor #FF9900
skinparam actorBorderColor #FF6600
skinparam actorFontColor #FFFFFF
skinparam usecaseBackgroundColor #232F3E
skinparam usecaseBorderColor #FF9900
skinparam usecaseFontColor #FFFFFF
skinparam packageBackgroundColor #2D3748
skinparam packageBorderColor #FF9900
skinparam packageFontColor #FF9900
skinparam arrowColor #FF9900

actor Estudiante
actor Profesor
actor Admin

package "Academia Virtual de Matematicas" {
  usecase "Crear plantillas con parametros variables" as EJP01
  usecase "Definir rangos y restricciones de parametros" as EJP02
  usecase "Cargar paso a paso oficial con LaTeX" as EJP03
  usecase "Previsualizar variantes antes de publicar" as EJP04
  usecase "Configurar pistas progresivas" as EJP05
  usecase "Resolver ejercicios con valores distintos" as EJP06
  usecase "Escribir paso a paso de resolucion" as EJP07
  usecase "Acceder a pistas progresivas" as EJP08
  usecase "Ver solucion oficial paso a paso" as EJP09
  usecase "Verificacion automatica de respuesta" as EJP10
  usecase "Adaptar dificultad segun nivel del estudiante" as EJP11
  usecase "Ver historial de intentos por ejercicio" as EJP12
  usecase "Repasar con flashcards automaticas" as EJP13
  usecase "Integrar ejercicios parametrizados en examenes" as EJP14
  usecase "Autenticar Usuario" as AUCX
  usecase "Registrar Auditoria" as AUD
}

Profesor --> EJP01
Profesor --> EJP02
Profesor --> EJP03
Profesor --> EJP04
Profesor --> EJP05
Estudiante --> EJP06
Estudiante --> EJP07
Estudiante --> EJP08
Estudiante --> EJP09
Estudiante --> EJP12
Estudiante --> EJP13
Admin --> EJP14

EJP01 ..> EJP02 : <<include>>
EJP01 ..> EJP03 : <<include>>
EJP06 ..> EJP10 : <<include>>
EJP06 ..> EJP11 : <<include>>
EJP06 ..> AUD : <<include>>
EJP14 ..> EJP11 : <<include>>
EJP01 ..> AUCX : <<include>>
EJP06 ..> AUCX : <<include>>

@enduml
