@startuml
left to right direction
!theme aws-orange

actor Estudiante
actor Profesor
actor Admin

package "Academia Virtual de Matematicas" {
  package "Foro" {
    usecase "Publicar dudas en el foro" as FOR01
    usecase "Votar las respuestas mas utiles" as FOR02
    usecase "Escribir formulas en publicaciones" as FOR03
    usecase "Marcar respuesta correcta" as FOR04
    usecase "Moderar publicaciones inapropiadas" as FOR05
    usecase "Adjuntar capturas de ejercicios" as FOR06
    usecase "Recibir notificacion de respuesta en foro" as FOR07
  }
  package "Clases en Vivo" {
    usecase "Programar clases en vivo" as CLV01
    usecase "Recibir notificacion de inicio de clase" as CLV02
    usecase "Ver grabacion de clases" as CLV03
    usecase "Usar chat durante la clase" as CLV04
    usecase "Ver registro de asistencia" as CLV05
    usecase "Usar pizarra digital interactiva" as CLV06
  }
  package "Notificaciones" {
    usecase "Recibir notificaciones de nuevo contenido" as NOT01
    usecase "Configurar notificaciones preferidas" as NOT02
    usecase "Ver historial de notificaciones" as NOT03
    usecase "Enviar notificaciones masivas" as NOT04
    usecase "Recibir push en celular" as NOT05
  }
}

Estudiante --> FOR01
Estudiante --> FOR02
Estudiante --> FOR03
Estudiante --> FOR06
Estudiante --> FOR07
Profesor --> FOR04
Admin --> FOR05

Profesor --> CLV01
Estudiante --> CLV02
Estudiante --> CLV03
Estudiante --> CLV04
Profesor --> CLV05
Profesor --> CLV06

Estudiante --> NOT01
Estudiante --> NOT02
Estudiante --> NOT03
Estudiante --> NOT05
Admin --> NOT04

FOR01 ..> FOR03 : <<include>>
FOR01 ..> FOR07 : <<include>>
CLV01 ..> CLV02 : <<include>>

@enduml
