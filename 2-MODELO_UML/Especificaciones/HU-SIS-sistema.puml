@startuml
left to right direction
!theme aws-orange

actor Admin

package "Academia Virtual de Matematicas" {
  package "Administracion" {
    usecase "Ver dashboard con metricas clave" as ADM01
    usecase "Publicar, archivar o despublicar cursos" as ADM02
    usecase "Enviar comunicados a todos los usuarios" as ADM03
    usecase "Recibir alertas de errores criticos" as ADM04
    usecase "Gestionar SEO de paginas de cursos" as ADM05
  }
  package "Auditoria y Logs" {
    usecase "Ver historial de acciones criticas" as AUD01
    usecase "Filtrar logs por usuario, accion y fecha" as AUD02
    usecase "Recibir alertas ante actividad sospechosa" as AUD03
    usecase "Exportar logs en CSV" as AUD04
    usecase "Conservar logs por 12 meses" as AUD05
  }
  package "Configuracion del Sistema" {
    usecase "Configurar nombre, logo y colores" as CFG01
    usecase "Activar o desactivar modulos" as CFG02
    usecase "Configurar integraciones externas" as CFG03
    usecase "Programar copias de seguridad automaticas" as CFG04
    usecase "Configurar cuota de almacenamiento" as CFG05
  }
}

Admin --> ADM01
Admin --> ADM02
Admin --> ADM03
Admin --> ADM04
Admin --> ADM05

Admin --> AUD01
Admin --> AUD02
Admin --> AUD03
Admin --> AUD04

Admin --> CFG01
Admin --> CFG02
Admin --> CFG03
Admin --> CFG04
Admin --> CFG05

AUD01 ..> AUD02 : <<include>>
AUD01 ..> AUD05 : <<include>>
CFG03 ..> CFG04 : <<extend>>

@enduml
