@startuml HU-GAM-gamificacion

left to right direction

title Modulo de Gamificacion

skinparam backgroundColor #1A1A2E
skinparam actor {
    BackgroundColor #FF9900
    BorderColor #FF6600
    FontColor #FFFFFF
}
skinparam usecase {
    BackgroundColor #232F3E
    BorderColor #FF9900
    FontColor #FFFFFF
}
skinparam package {
    BackgroundColor #2D3748
    BorderColor #FF9900
    FontColor #FF9900
}
skinparam arrowColor #FF9900
skinparam note {
    BackgroundColor #2D3748
    BorderColor #FF9900
    FontColor #FFFFFF
}
skinparam legend {
    BackgroundColor #2D3748
    BorderColor #FF9900
    FontColor #FFFFFF
}

actor "Estudiante" as EST
actor "Profesor" as PROF
actor "Administrador" as ADM

package "Academia Virtual de Matematicas" {
    package "Gamificacion" {

        ' --- EXPERIENCIA Y NIVELES ---
        usecase "Ganar XP al completar\ntemas y examenes" as GAM01

        usecase "Subir de nivel al\nacumular XP" as GAM04

        usecase "Ver barra de progreso\nhacia siguiente nivel" as GAM08

        ' --- RANKING Y COMPETENCIA ---
        usecase "Ver ranking semanal\ny mensual" as GAM02

        usecase "Ver ranking por\ncurso o tema" as GAM09

        usecase "Desafiar a otro\nestudiante" as GAM10

        ' --- INSIGNIAS Y LOGROS ---
        usecase "Ganar insignias por\nlogros especificos" as GAM03

        usecase "Ver insignias en\nel perfil" as GAM05

        usecase "Compartir insignias en\nredes sociales" as GAM11

        usecase "Ver coleccion de\ninsignias desbloqueadas" as GAM12

        ' --- RECOMPENSAS ---
        usecase "Canjear puntos por\nrecompensas" as GAM13

        usecase "Ver tienda de\nrecompensas" as GAM14

        ' --- GESTION (Admin/Profesor) ---
        usecase "Configurar criterios\nde cada logro" as GAM06

        usecase "Notificar al estudiante\npor logros" as GAM07

        usecase "Crear desafios\nespeciales" as GAM15

        usecase "Configurar tabla de\nniveles y XP requerido" as GAM16
    }
}

' --- ESTUDIANTE ---
EST --> GAM01
EST --> GAM02
EST --> GAM03
EST --> GAM04
EST --> GAM05
EST --> GAM08
EST --> GAM09
EST --> GAM10
EST --> GAM11
EST --> GAM12
EST --> GAM13
EST --> GAM14

' --- PROFESOR ---
PROF --> GAM06
PROF --> GAM07
PROF --> GAM15

' --- ADMINISTRADOR ---
ADM --> GAM06
ADM --> GAM07
ADM --> GAM16

' --- RELACIONES <<include>> ---
GAM01 ..> GAM04 : <<include>>
GAM04 ..> GAM08 : <<include>>

GAM03 ..> GAM05 : <<include>>
GAM05 ..> GAM12 : <<include>>

GAM13 ..> GAM14 : <<include>>

GAM06 ..> GAM07 : <<include>>
GAM15 ..> GAM07 : <<include>>

' --- RELACIONES <<extend>> ---
GAM10 ..> GAM02 : <<extend>>
GAM11 ..> GAM05 : <<extend>>
GAM09 ..> GAM02 : <<extend>>

' --- NOTAS EXPLICATIVAS ---
note right of GAM01
  El estudiante gana XP al:
  - Completar un tema (50 XP)
  - Aprobar un examen (100 XP)
  - Resolver ejercicios sin pistas (20 XP extra)
  - Mantener racha de estudio (bonus diario)
end note

note right of GAM03
  Tipos de insignias disponibles:
  - "Primeros pasos" (completar 1 tema)
  - "Resolutor" (resolver 100 ejercicios)
  - "Racha perfecta" (7 dias seguidos)
  - "Maestro" (aprobar examen con 95%+)
  - "Colaborador" (ayudar en foro 10 veces)
end note

note right of GAM02
  Rankings disponibles:
  - Global de la plataforma
  - Por curso matriculado
  - Por tema especifico
  - Por grupo de estudio
end note

note right of GAM13
  Recompensas canjeables:
  - Desbloquear temas avanzados
  - Acceso a examenes de practica extra
  - Personalizacion de avatar
  - Insignias exclusivas de edicion limitada
end note

' --- LEYENDA ---
legend right

| |= LEYENDA - Gamificacion | |
| --> | Asociacion actor -> caso de uso |
| ..> | Dependencia UML |
| <<include>> | Flujo obligatorio |
| <<extend>> | Flujo alternativo |

endlegend

@enduml