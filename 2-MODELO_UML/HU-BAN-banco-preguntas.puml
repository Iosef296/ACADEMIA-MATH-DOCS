@startuml HU-BAN-banco-preguntas

left to right direction

title Modulo de Banco de Preguntas

skinparam backgroundColor #1A1A2E
skinparam actor {
    BackgroundColor #FF9900
    BorderColor #FF6600
    FontColor #FFFFFF
}
skinparam usecase {
    BackgroundColor #232F3E
    BorderColor #FF9900
    FontColor #FFFFFF
}
skinparam package {
    BackgroundColor #2D3748
    BorderColor #FF9900
    FontColor #FF9900
}
skinparam arrowColor #FF9900
skinparam note {
    BackgroundColor #2D3748
    BorderColor #FF9900
    FontColor #FFFFFF
}
skinparam legend {
    BackgroundColor #2D3748
    BorderColor #FF9900
    FontColor #FFFFFF
}

actor "Profesor" as PROF
actor "Administrador" as ADM

package "Academia Virtual de Matematicas" {
    package "Banco de Preguntas" {

        usecase "Crear preguntas con\ntipos variados" as BPR01

        usecase "Asignar dificultad a\ncada pregunta" as BPR02

        usecase "Buscar preguntas por\ncategoria y tag" as BPR03

        usecase "Importar preguntas\ndesde Excel" as BPR04

        usecase "Ver uso de preguntas\nen examenes" as BPR05

        usecase "Exportar banco de\npreguntas" as BPR06

        usecase "Clonar y versionar\npreguntas" as BPR07
    }
}

PROF --> BPR01
PROF --> BPR02
PROF --> BPR03
PROF --> BPR04
PROF --> BPR06
PROF --> BPR07

ADM --> BPR05
ADM --> BPR06
ADM --> BPR07

BPR01 ..> BPR02 : <<include>>
BPR04 ..> BPR02 : <<include>>
BPR07 ..> BPR01 : <<extend>>

note right of BPR01
  Tipos de preguntas disponibles:
  - Opcion multiple
  - Verdadero / Falso
  - Respuesta corta
  - Desarrollo (con rubrica)
  - Emparejamiento
  - Completar espacios
end note

note right of BPR05
  El administrador puede ver:
  - Cuantas veces se uso cada pregunta
  - En que examenes aparece
  - Tasa de acierto de los estudiantes
end note

legend right

| |= LEYENDA | |
| --> | Asociacion actor -> caso de uso |
| ..> | Dependencia UML |
| <<include>> | Flujo obligatorio |
| <<extend>> | Flujo alternativo |

endlegend

@enduml