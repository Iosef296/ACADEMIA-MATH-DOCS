@startuml HU-PAG-pagos-suscripciones

left to right direction

title Modulo de Pagos y Suscripciones

skinparam backgroundColor #1A1A2E
skinparam actor {
    BackgroundColor #FF9900
    BorderColor #FF6600
    FontColor #FFFFFF
}
skinparam usecase {
    BackgroundColor #232F3E
    BorderColor #FF9900
    FontColor #FFFFFF
}
skinparam package {
    BackgroundColor #2D3748
    BorderColor #FF9900
    FontColor #FF9900
}
skinparam arrowColor #FF9900
skinparam note {
    BackgroundColor #2D3748
    BorderColor #FF9900
    FontColor #FFFFFF
}
skinparam legend {
    BackgroundColor #2D3748
    BorderColor #FF9900
    FontColor #FFFFFF
}

actor "Estudiante" as EST
actor "Administrador" as ADM

package "Academia Virtual de Matematicas" {
    package "Pagos y Suscripciones" {

        ' --- EXPLORACION Y SELECCION ---
        usecase "Ver planes y\nsus precios" as PAG01

        usecase "Comparar beneficios de\ncada plan" as PAG09

        usecase "Aplicar codigo de\ndescuento" as PAG04

        ' --- PAGO Y FACTURACION ---
        usecase "Pagar con tarjeta de\nforma segura" as PAG02

        usecase "Pagar con transferencia\nbancaria" as PAG10

        usecase "Pagar con billetera\ndigital" as PAG11

        usecase "Descargar comprobante\nde pago" as PAG03

        usecase "Generar factura\nelectronica" as PAG12

        ' --- SUSCRIPCION Y ACCESO ---
        usecase "Matricularse en un\ncurso especifico" as PAG08

        usecase "Activar suscripcion\nautomatica" as PAG13

        usecase "Pausar suscripcion\ntemporariamente" as PAG14

        usecase "Cancelar suscripcion" as PAG15

        ' --- NOTIFICACIONES Y RECORDATORIOS ---
        usecase "Recibir aviso de\nvencimiento de suscripcion" as PAG05

        usecase "Recibir recordatorio de\nrenovacion" as PAG16

        ' --- GESTION (Admin) ---
        usecase "Ver historial de pagos" as PAG06

        usecase "Configurar periodo de\nprueba gratuito" as PAG07

        usecase "Gestionar planes y\nprecios" as PAG17

        usecase "Ver reporte de\ningresos" as PAG18

        usecase "Procesar reembolsos" as PAG19

        usecase "Verificar estado de\npago pendiente" as PAG20
    }
}

' --- ESTUDIANTE ---
EST --> PAG01
EST --> PAG04
EST --> PAG02
EST --> PAG03
EST --> PAG08
EST --> PAG05
EST --> PAG09
EST --> PAG10
EST --> PAG11
EST --> PAG12
EST --> PAG13
EST --> PAG14
EST --> PAG15
EST --> PAG16

' --- ADMINISTRADOR ---
ADM --> PAG06
ADM --> PAG07
ADM --> PAG17
ADM --> PAG18
ADM --> PAG19
ADM --> PAG20

' --- RELACIONES <<include>> ---
PAG01 ..> PAG09 : <<include>>
PAG02 ..> PAG03 : <<include>>
PAG02 ..> PAG12 : <<include>>

PAG08 ..> PAG02 : <<include>>

PAG13 ..> PAG05 : <<include>>
PAG13 ..> PAG16 : <<include>>

' --- RELACIONES <<extend>> ---
PAG04 ..> PAG02 : <<extend>>
PAG10 ..> PAG02 : <<extend>>
PAG11 ..> PAG02 : <<extend>>

PAG14 ..> PAG15 : <<extend>>
PAG19 ..> PAG06 : <<extend>>

' --- NOTAS EXPLICATIVAS ---
note right of PAG01
  Planes disponibles:
  - Basico: acceso a temas basicos
  - Pro: acceso completo + examenes
  - Premium: clases en vivo + mentorias
end note

note right of PAG02
  El pago con tarjeta utiliza:
  - Encriptacion SSL/TLS
  - Tokenizacion de datos sensibles
  - Integracion con pasarela de pago (Stripe/PayU)
end note

note right of PAG08
  Al matricularse, el estudiante:
  - Selecciona el curso deseado
  - Verifica prerequisitos
  - Confirma pago o suscripcion activa
  - Recibe acceso inmediato al contenido
end note

note right of PAG05
  Avisos de vencimiento:
  - 7 dias antes: email informativo
  - 3 dias antes: push + email
  - 1 dia antes: push urgente
  - Vencido: bloqueo de contenido premium
end note

' --- LEYENDA ---
legend right

| |= LEYENDA - Pagos y Suscripciones | |
| --> | Asociacion actor -> caso de uso |
| ..> | Dependencia UML |
| <<include>> | Flujo obligatorio |
| <<extend>> | Flujo alternativo |

endlegend

@enduml