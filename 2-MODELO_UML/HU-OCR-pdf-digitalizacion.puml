@startuml HU-OCR-pdf-digitalizacion

left to right direction

title Modulo de PDF y OCR

skinparam backgroundColor #1A1A2E
skinparam actor {
    BackgroundColor #FF9900
    BorderColor #FF6600
    FontColor #FFFFFF
}
skinparam usecase {
    BackgroundColor #232F3E
    BorderColor #FF9900
    FontColor #FFFFFF
}
skinparam package {
    BackgroundColor #2D3748
    BorderColor #FF9900
    FontColor #FF9900
}
skinparam arrowColor #FF9900
skinparam note {
    BackgroundColor #2D3748
    BorderColor #FF9900
    FontColor #FFFFFF
}
skinparam legend {
    BackgroundColor #2D3748
    BorderColor #FF9900
    FontColor #FFFFFF
}

actor "Estudiante" as EST
actor "Profesor" as PROF

package "Academia Virtual de Matematicas" {
    package "PDF y OCR" {

        usecase "Subir PDFs de apuntes" as OCR01

        usecase "Extraer texto\nautomaticamente (OCR)" as OCR02

        usecase "Convertir formulas\nescaneadas a LaTeX" as OCR03

        usecase "Corregir texto extraido\nantes de publicar" as OCR04

        usecase "Previsualizar PDF en\nla plataforma" as OCR05

        usecase "Recibir notificacion\ncuando OCR termine" as OCR06
    }
}

EST --> OCR05

PROF --> OCR01
PROF --> OCR04
PROF --> OCR06

OCR01 ..> OCR02 : <<include>>
OCR02 ..> OCR03 : <<include>>
OCR02 ..> OCR06 : <<include>>
OCR04 ..> OCR02 : <<extend>>

note right of OCR02
  El sistema utiliza Tesseract OCR para
  extraer texto de PDFs escaneados y
  convertir formulas a codigo LaTeX
end note

note right of OCR04
  El profesor puede editar el texto extraido
  antes de publicarlo como contenido oficial
end note

legend right

| |= LEYENDA | |
| --> | Asociacion actor -> caso de uso |
| ..> | Dependencia UML |
| <<include>> | Flujo obligatorio |
| <<extend>> | Flujo alternativo |

endlegend

@enduml