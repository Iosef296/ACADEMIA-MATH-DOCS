@startjson
{
  "Caso de uso": "Configurar Parametros Globales del Sistema",
  "Id": "CU-05",
  "Breve descripcion": "El administrador configura los parametros globales de la plataforma: identidad de marca, modulos activos, integraciones con servicios externos, politicas de backup, parametros de gamificacion, configuracion de IA y canales de notificaciones.",
  "Actores primarios": "Administrador",
  "Actores secundarios": "Servicios Externos (Stripe, AWS S3, Google Analytics, SendGrid), Base de Datos de Configuracion, Servicio de Cache",
  "Precondiciones": [
    "El administrador tiene rol 'SuperAdmin' o 'Configurador' asignado.",
    "El sistema esta en modo mantenimiento o ventana de bajo trafico para cambios criticos que requieren reinicio.",
    "Los servicios externos a integrar tienen credenciales validas y cuentas activas."
  ],
  "Flujo principal": {
    "1": "El administrador accede al modulo 'Configuracion del Sistema' desde el panel administrativo.",
    "2": "El sistema muestra las categorias de configuracion: Marca, Modulos, Integraciones, Backups, Gamificacion, Inteligencia Artificial, Notificaciones, Seguridad.",
    "3": "El administrador selecciona una categoria para configurar.",
    "4": "Para Marca: edita nombre de la plataforma, sube logo, define paleta de colores primaria/secundaria, tipografia, terminos legales y politica de privacidad.",
    "5": "Para Modulos: activa o desactiva funcionalidades completas (foro, clases en vivo, gamificacion, IA recomendaciones, ejercicios parametrizados, OCR).",
    "6": "Para Integraciones: configura APIs de pasarela de pago, almacenamiento en cloud, servicio de email, Google Analytics, autenticacion SSO (SAML/OAuth).",
    "7": "El sistema valida las credenciales de API en tiempo real realizando ping al servicio externo y muestra estado de conexion.",
    "8": "Para Backups: programa frecuencia (hora/dia), destino (local/cloud), politica de retencion (dias/meses) y notificaciones de exito/fallo.",
    "9": "Para Gamificacion: define reglas de puntuacion XP por actividad, umbrales de niveles, multiplicadores de eventos y recompensas de tienda.",
    "10": "El administrador guarda los cambios; el sistema aplica inmediatamente los que no requieren reinicio, o programa los criticos para la proxima ventana de mantenimiento.",
    "11": "El sistema (Auditoria Service) registra todos los cambios de configuracion con valor anterior y nuevo, IP y timestamp."
  },
  "Postcondiciones": [
    "Los cambios de marca se reflejan inmediatamente en toda la interfaz de usuario de la plataforma.",
    "Los modulos desactivados no son accesibles para ningun usuario ni aparecen en menus.",
    "Las integraciones configuradas estan operativas, monitoreadas y con health-check activo.",
    "Los backups se ejecutan automaticamente segun la programacion definida.",
    "El historial de cambios de configuracion queda completo para auditoria y posible rollback."
  ],
  "Flujos alternativos": {
    "A1: Credenciales de API invalidas": "El sistema muestra error especifico del servicio externo, no permite guardar la configuracion hasta corregir y sugiere verificar documentacion del proveedor.",
    "A2: Dependencia entre modulos": "Si se intenta desactivar 'Ejercicios Parametrizados', el sistema advierte que 'Examenes' y 'IA Recomendaciones' dependen de este modulo y se veran afectados; requiere confirmacion explicita.",
    "A3: Cambio en horario de backup con job en ejecucion": "El sistema detecta backup en progreso, muestra advertencia y no permite reprogramar hasta que finalice el job actual.",
    "A4: Rollback de configuracion": "El administrador puede seleccionar fecha/hora anterior desde el historial de cambios y restaurar configuracion completa o parcial; el sistema confirma impacto antes de aplicar.",
    "A5: Configuracion en entorno productivo sin mantenimiento": "El sistema advierte que el cambio requiere reinicio y afectara a usuarios activos; permite programar para ventana nocturna o requiere doble confirmacion."
  }
}
@endjson