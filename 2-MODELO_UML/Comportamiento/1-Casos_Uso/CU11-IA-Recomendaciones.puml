@startuml HU-IAR-ia-recomendaciones

left to right direction

title Modulo de IA y Recomendaciones

skinparam backgroundColor #1A1A2E
skinparam actor {
    BackgroundColor #FF9900
    BorderColor #FF6600
    FontColor #FFFFFF
}
skinparam usecase {
    BackgroundColor #232F3E
    BorderColor #FF9900
    FontColor #FFFFFF
}
skinparam package {
    BackgroundColor #2D3748
    BorderColor #FF9900
    FontColor #FF9900
}
skinparam arrowColor #FF9900
skinparam note {
    BackgroundColor #2D3748
    BorderColor #FF9900
    FontColor #FFFFFF
}
skinparam legend {
    BackgroundColor #2D3748
    BorderColor #FF9900
    FontColor #FFFFFF
}

actor "Estudiante" as EST
actor "Profesor" as PROF
actor "Administrador" as ADM

package "Academia Virtual de Matematicas" {
    package "IA y Recomendaciones" {

        ' --- RECOMENDACIONES ADAPTATIVAS ---
        usecase "Recibir ejercicios recomendados\nsegun areas debiles" as IAR01

        usecase "Ajustar dificultad de\nparametros adaptativamente" as IAR02

        usecase "Recibir sugerencia del\nsiguiente tema a estudiar" as IAR04

        usecase "Generar plan de estudio\npersonalizado con IA" as IAR07

        ' --- ASISTENTE IA ---
        usecase "Consultar al asistente IA\ndudas matematicas" as IAR03

        usecase "Recibir explicacion paso a paso\nde un ejercicio con IA" as IAR08

        usecase "Escalar duda a profesor\ncuando IA no puede resolver" as IAR09

        ' --- REPORTES Y ANALISIS ---
        usecase "Recibir resumen semanal\nde desempeno" as IAR05

        usecase "Ver prediccion de nota\nen examen final" as IAR10

        usecase "Identificar patrones de\nerror con IA" as IAR11

        ' --- ALERTAS Y SUPERVISION ---
        usecase "Recibir alertas sobre\nerrores recurrentes en EJP" as IAR06

        usecase "Ver dashboard de riesgo\nde desercion" as IAR12

        ' --- GESTION DE MODELOS (Admin) ---
        usecase "Entrenar modelo de\nrecomendacion con datos nuevos" as IAR13

        usecase "Configurar parametros del\nasistente IA" as IAR14

        usecase "Auditar respuestas del\nasistente IA" as IAR15
    }
}

' --- ESTUDIANTE ---
EST --> IAR01
EST --> IAR02
EST --> IAR03
EST --> IAR04
EST --> IAR05
EST --> IAR07
EST --> IAR08
EST --> IAR10

' --- PROFESOR ---
PROF --> IAR06
PROF --> IAR09
PROF --> IAR11
PROF --> IAR12
PROF --> IAR15

' --- ADMINISTRADOR ---
ADM --> IAR13
ADM --> IAR14
ADM --> IAR15

' --- RELACIONES <<include>> ---
IAR01 ..> IAR02 : <<include>>
IAR04 ..> IAR07 : <<include>>

IAR03 ..> IAR08 : <<include>>
IAR03 ..> IAR09 : <<include>>

IAR05 ..> IAR11 : <<include>>
IAR06 ..> IAR11 : <<include>>

IAR12 ..> IAR11 : <<include>>

' --- RELACIONES <<extend>> ---
IAR10 ..> IAR05 : <<extend>>
IAR08 ..> IAR01 : <<extend>>

' --- NOTAS EXPLICATIVAS ---
note right of IAR01
  El sistema analiza el historial de errores
  del estudiante y genera ejercicios del EJP
  enfocados en las areas donde tiene menor
  precision (algebra, calculo, estadistica, etc.)
end note

note right of IAR03
  El asistente IA utiliza un modelo LLM
  especializado en matematicas universitarias.
  Puede resolver dudas, explicar conceptos
  y guiar paso a paso sin dar la respuesta directa.
end note

note right of IAR06
  El profesor recibe alertas cuando:
  - Un estudiante comete el mismo error > 3 veces
  - La tasa de error en un tema supera el 70%
  - Se detecta un patron de confusion conceptual
end note

note right of IAR10
  La prediccion de nota se basa en:
  - Desempeno historico en ejercicios
  - Tiempo de estudio dedicado
  - Precision en examenes de practica
  - Comparativa con cohortes anteriores
end note

' --- LEYENDA ---
legend right

| |= LEYENDA - IA y Recomendaciones | |
| --> | Asociacion actor -> caso de uso |
| ..> | Dependencia UML |
| <<include>> | Flujo obligatorio |
| <<extend>> | Flujo alternativo |

endlegend

@enduml