@startuml HU-PRO-progreso-rutinas

left to right direction

title Modulo de Progreso y Rutinas

skinparam backgroundColor #1A1A2E
skinparam actor {
    BackgroundColor #FF9900
    BorderColor #FF6600
    FontColor #FFFFFF
}
skinparam usecase {
    BackgroundColor #232F3E
    BorderColor #FF9900
    FontColor #FFFFFF
}
skinparam package {
    BackgroundColor #2D3748
    BorderColor #FF9900
    FontColor #FF9900
}
skinparam arrowColor #FF9900
skinparam note {
    BackgroundColor #2D3748
    BorderColor #FF9900
    FontColor #FFFFFF
}
skinparam legend {
    BackgroundColor #2D3748
    BorderColor #FF9900
    FontColor #FFFFFF
}

actor "Estudiante" as EST
actor "Profesor" as PROF

package "Academia Virtual de Matematicas" {
    package "Progreso y Rutinas" {

        usecase "Ver porcentaje de\navance por curso" as PRG01

        usecase "Recibir plan de estudio\nsemanal personalizado" as PRG02

        usecase "Ver racha de dias\nde estudio" as PRG03

        usecase "Definir metas de estudio" as PRG04

        usecase "Recibir recordatorios\nde estudio" as PRG05

        usecase "Ver calendario\nacademico completo" as PRG06

        usecase "Ver tiempo de\nestudio diario" as PRG07

        usecase "Ver grafico de\nprogreso historico" as PRG08

        usecase "Comparar progreso\ncon metas definidas" as PRG09
    }
}

EST --> PRG01
EST --> PRG02
EST --> PRG03
EST --> PRG04
EST --> PRG05
EST --> PRG06
EST --> PRG07
EST --> PRG08
EST --> PRG09

PROF --> PRG06

PRG02 ..> PRG04 : <<include>>
PRG05 ..> PRG04 : <<include>>
PRG09 ..> PRG01 : <<include>>
PRG09 ..> PRG04 : <<include>>

PRG03 ..> PRG07 : <<extend>>

note right of PRG02
  El plan de estudio semanal se genera
  automaticamente basado en:
  - Metas definidas por el estudiante
  - Temas pendientes o atrasados
  - Ritmo de aprendizaje historico
end note

note right of PRG03
  La racha de dias muestra:
  - Dias consecutivos estudiando
  - Record personal
  - Comparativa con amigos (opcional)
end note

note right of PRG09
  El estudiante puede comparar su progreso
  real vs. las metas que definio al inicio
  del curso o semestre.
end note

legend right

| |= LEYENDA - Progreso y Rutinas | |
| --> | Asociacion actor -> caso de uso |
| ..> | Dependencia UML |
| <<include>> | Flujo obligatorio |
| <<extend>> | Flujo alternativo |

endlegend

@enduml