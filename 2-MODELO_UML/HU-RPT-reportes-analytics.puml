@startuml HU-RPT-reportes-analytics

left to right direction

title Modulo de Reportes y Analytics

skinparam backgroundColor #1A1A2E
skinparam actor {
    BackgroundColor #FF9900
    BorderColor #FF6600
    FontColor #FFFFFF
}
skinparam usecase {
    BackgroundColor #232F3E
    BorderColor #FF9900
    FontColor #FFFFFF
}
skinparam package {
    BackgroundColor #2D3748
    BorderColor #FF9900
    FontColor #FF9900
}
skinparam arrowColor #FF9900
skinparam note {
    BackgroundColor #2D3748
    BorderColor #FF9900
    FontColor #FFFFFF
}
skinparam legend {
    BackgroundColor #2D3748
    BorderColor #FF9900
    FontColor #FFFFFF
}

actor "Profesor" as PROF
actor "Administrador" as ADM

package "Academia Virtual de Matematicas" {
    package "Reportes y Analytics" {

        usecase "Ver rendimiento de\nestudiantes por tema" as REP01

        usecase "Ver ranking de\nestudiantes" as REP02

        usecase "Exportar reportes en\nPDF o Excel" as REP03

        usecase "Ver dashboard de\nmetricas en tiempo real" as REP04

        usecase "Ver tasa de error por\ntipo de ejercicio" as REP05

        usecase "Ver rendimiento por\nejercicio parametrizado" as REP06

        usecase "Generar alertas de\nestudiantes en riesgo" as REP07

        usecase "Comparar cohortes\npor periodo academico" as REP08
    }
}

PROF --> REP01
PROF --> REP02
PROF --> REP05
PROF --> REP06

ADM --> REP03
ADM --> REP04
ADM --> REP07
ADM --> REP08

REP01 ..> REP05 : <<include>>
REP01 ..> REP06 : <<include>>

REP04 ..> REP07 : <<include>>

REP08 ..> REP01 : <<extend>>
REP08 ..> REP02 : <<extend>>

note right of REP01
  El profesor puede filtrar por:
  - Curso, unidad o tema especifico
  - Rango de fechas
  - Grupo de estudiantes
end note

note right of REP04
  El dashboard muestra en tiempo real:
  - Estudiantes activos
  - Ejercicios resueltos por hora
  - Temas con mayor dificultad
  - Alertas automaticas
end note

note right of REP07
  El sistema detecta automaticamente:
  - Estudiantes sin actividad > 7 dias
  - Tasa de error > 70% en un tema
  - Riesgo de desercion academica
end note

legend right

| |= LEYENDA - Reportes y Analytics | |
| --> | Asociacion actor -> caso de uso |
| ..> | Dependencia UML |
| <<include>> | Flujo obligatorio |
| <<extend>> | Flujo alternativo |

endlegend

@enduml