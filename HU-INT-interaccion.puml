@startuml HU-INT-interaccion

left to right direction

title Modulo de Foro e Interaccion

skinparam backgroundColor #1A1A2E
skinparam actor {
    BackgroundColor #FF9900
    BorderColor #FF6600
    FontColor #FFFFFF
}
skinparam usecase {
    BackgroundColor #232F3E
    BorderColor #FF9900
    FontColor #FFFFFF
}
skinparam package {
    BackgroundColor #2D3748
    BorderColor #FF9900
    FontColor #FF9900
}
skinparam arrowColor #FF9900
skinparam note {
    BackgroundColor #2D3748
    BorderColor #FF9900
    FontColor #FFFFFF
}
skinparam legend {
    BackgroundColor #2D3748
    BorderColor #FF9900
    FontColor #FFFFFF
}

actor "Estudiante" as EST
actor "Profesor" as PROF
actor "Administrador" as ADM

package "Academia Virtual de Matematicas" {
    package "Foro e Interaccion" {

        usecase "Publicar dudas en el foro" as FOR01

        usecase "Votar las respuestas\nmas utiles" as FOR02

        usecase "Escribir formulas en\npublicaciones (LaTeX)" as FOR03

        usecase "Marcar respuesta como\ncorrecta" as FOR04

        usecase "Moderar publicaciones\ninapropiadas" as FOR05

        usecase "Adjuntar capturas de\nejercicios" as FOR06

        usecase "Recibir notificacion de\nrespuesta en foro" as FOR07

        usecase "Buscar publicaciones por\ntema o palabra clave" as FOR08

        usecase "Seguir a un usuario del\nforo" as FOR09

        usecase "Ver perfil de contribucion\nen el foro" as FOR10
    }
}

EST --> FOR01
EST --> FOR02
EST --> FOR03
EST --> FOR06
EST --> FOR07
EST --> FOR08
EST --> FOR09
EST --> FOR10

PROF --> FOR01
PROF --> FOR02
PROF --> FOR03
PROF --> FOR04
PROF --> FOR06
PROF --> FOR07
PROF --> FOR08
PROF --> FOR10

ADM --> FOR05

FOR01 ..> FOR03 : <<include>>
FOR01 ..> FOR07 : <<include>>
FOR04 ..> FOR02 : <<include>>

FOR09 ..> FOR10 : <<extend>>

note right of FOR01
  Al publicar una duda, el estudiante puede:
  - Titulo descriptivo
  - Descripcion con formulas LaTeX
  - Adjuntar imagenes del ejercicio
  - Seleccionar tema y curso relacionado
end note

note right of FOR03
  El editor de publicaciones soporta:
  - Formulas matematicas en LaTeX
  - Preview en tiempo real
  - Atajos de simbolos frecuentes
end note

note right of FOR04
  Solo el autor de la pregunta o un profesor
  puede marcar una respuesta como correcta.
  Esto otorga puntos de reputacion al respondedor.
end note

note right of FOR05
  El administrador puede:
  - Ocultar publicaciones inapropiadas
  - Suspender usuarios reincidentes
  - Ver reportes de la comunidad
end note

legend right

| |= LEYENDA - Foro e Interaccion | |
| --> | Asociacion actor -> caso de uso |
| ..> | Dependencia UML |
| <<include>> | Flujo obligatorio |
| <<extend>> | Flujo alternativo |

endlegend

@enduml